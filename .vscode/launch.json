	"version": "0.2.0",
	"configurations": [
		{
			"name": "Launch app (Normal)",
			"type": "java",
			"request": "launch",
			"mainClass": "main.MainGL"
		},
		{
			"name": "Launch app (Debug)",
			"type": "java",
			"request": "launch",
			"mainClass": "main.DebugGL"
		},
		{
			"name": "Launch compiled app (bin/SpaceCubevaders.jar)",
			"type": "node-terminal",
			"request": "launch",
			"command": "& \"C:\\Program Files\\Java\\jdk-15.0.2\\bin\\java.exe\" -D'sun.java2d.d3d=false' -jar bin/SpaceCubevaders.jar",
			"cwd": "${workspaceFolder}"
		}
	]
}